{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phaser-game-engines.dev/schemas/core/world.schema.json",
  "title": "Phaser Game Engines world",
  "type": "object",
  "required": ["world", "spawn"],
  "properties": {
    "schemaVersion": { "const": 1, "default": 1 },
    "world": { "$ref": "#/$defs/world" },
    "spawn": { "$ref": "#/$defs/point" },
    "entitySpecs": { "type": "array", "items": { "$ref": "#/$defs/entity" }, "default": [] }
  },
  "additionalProperties": true,
  "$defs": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } },
      "additionalProperties": true
    },
    "rect": {
      "allOf": [{ "$ref": "#/$defs/point" }],
      "required": ["x", "y", "w", "h"],
      "properties": { "w": { "type": "number", "exclusiveMinimum": 0 }, "h": { "type": "number", "exclusiveMinimum": 0 } }
    },
    "world": {
      "type": "object",
      "required": ["width", "height"],
      "properties": { "width": { "type": "number", "exclusiveMinimum": 0 }, "height": { "type": "number", "exclusiveMinimum": 0 } },
      "additionalProperties": true
    },
    "entity": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "schemaVersion": { "const": 1, "default": 1 },
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}
