{
  "name": "@phaser-game-engines/core",
  "version": "0.1.0",
  "description": "Headless contracts shared by Phaser game-engine packages.",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./headless": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./*.js": {
      "types": "./types/*.d.ts",
      "default": "./src/*.js"
    },
    "./schemas/*.json": "./schemas/*.json"
  },
  "files": ["src", "types", "schemas", "README.md"],
  "sideEffects": false,
  "keywords": ["phaser", "game-engine", "headless", "deterministic"],
  "homepage": "https://github.com/MarcoABCardoso/phaser-game-engines#readme",
  "bugs": "https://github.com/MarcoABCardoso/phaser-game-engines/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoABCardoso/phaser-game-engines.git",
    "directory": "packages/core"
  },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=22" }
}
