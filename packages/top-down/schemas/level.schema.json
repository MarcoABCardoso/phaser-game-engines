{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phaser-game-engines.dev/schemas/top-down/level.schema.json",
  "title": "Top-down level",
  "allOf": [
    { "$ref": "https://phaser-game-engines.dev/schemas/core/world.schema.json" },
    {
      "type": "object",
      "properties": {
        "walls": { "type": "array", "items": { "$ref": "https://phaser-game-engines.dev/schemas/core/world.schema.json#/$defs/rect" }, "default": [] },
        "camera": {
          "type": "object",
          "properties": { "deadzoneWidth": { "type": "number", "minimum": 0 }, "deadzoneHeight": { "type": "number", "minimum": 0 } },
          "additionalProperties": true
        }
      }
    }
  ]
}
