{
  "name": "@phaser-game-engines/platformer",
  "version": "0.1.0",
  "description": "Reusable Phaser 3 / Arcade Physics platformer engine.",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./headless": {
      "types": "./types/headless.d.ts",
      "default": "./src/headless.js"
    },
    "./controllers": {
      "types": "./types/controllers/index.d.ts",
      "default": "./src/controllers/index.js"
    },
    "./controllers/*.js": {
      "types": "./types/controllers/*.d.ts",
      "default": "./src/controllers/*.js"
    },
    "./entities/*.js": {
      "types": "./types/entities/*.d.ts",
      "default": "./src/entities/*.js"
    },
    "./mechanics/*.js": {
      "types": "./types/mechanics/*.d.ts",
      "default": "./src/mechanics/*.js"
    },
    "./recipes/*.js": {
      "types": "./types/recipes/*.d.ts",
      "default": "./src/recipes/*.js"
    },
    "./recipes/*.js": {
      "types": "./types/recipes/*.d.ts",
      "default": "./src/recipes/*.js"
    },
    "./scenes/*.js": {
      "types": "./types/scenes/*.d.ts",
      "default": "./src/scenes/*.js"
    },
    "./systems/*.js": {
      "types": "./types/systems/*.d.ts",
      "default": "./src/systems/*.js"
    },
    "./schemas/*.json": "./schemas/*.json"
  },
  "files": [
    "src",
    "types",
    "schemas",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": ["phaser", "platformer", "arcade-physics", "game-engine"],
  "homepage": "https://github.com/MarcoABCardoso/phaser-game-engines/tree/main/packages/platformer#readme",
  "bugs": "https://github.com/MarcoABCardoso/phaser-game-engines/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoABCardoso/phaser-game-engines.git",
    "directory": "packages/platformer"
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@phaser-game-engines/core": "0.1.0"
  },
  "peerDependencies": {
    "phaser": "^3.90.0"
  },
  "engines": {
    "node": ">=22"
  }
}
