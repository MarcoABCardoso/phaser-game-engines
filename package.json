{
  "name": "phaser-game-engines",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/MarcoABCardoso/phaser-game-engines#readme",
  "bugs": "https://github.com/MarcoABCardoso/phaser-game-engines/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoABCardoso/phaser-game-engines.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:headless": "vitest run packages/toolkit/modules/core/tests/headless-exports.test.js",
    "build:types": "tsc -p packages/toolkit/modules/core/tsconfig.types.json && tsc -p packages/toolkit/modules/platformer/tsconfig.types.json && tsc -p packages/toolkit/modules/top-down/tsconfig.types.json && tsc -p packages/toolkit/modules/turn-based-battle/tsconfig.types.json && tsc -p packages/toolkit/modules/inventory/tsconfig.types.json",
    "typecheck": "tsc -p tests/types/tsconfig.json",
    "check:repo": "node scripts/check-repository.mjs",
    "check:versions": "node scripts/version-packages.mjs --check",
    "check:release": "node scripts/check-release-readiness.mjs",
    "prepare:release": "node scripts/prepare-release.mjs",
    "version:packages": "node scripts/version-packages.mjs",
    "verify:packages": "node scripts/verify-packages.mjs",
    "verify:starters": "node scripts/verify-starters.mjs",
    "verify:registry": "node scripts/verify-registry.mjs",
    "create:game": "node packages/create-game/bin/create-game.js",
    "sync:samples": "node scripts/sync-generator-samples.mjs",
    "check:samples": "node scripts/sync-generator-samples.mjs --check",
    "content": "node packages/toolkit/modules/content-tools/bin/pge-content.js",
    "verify": "npm run check:repo && npm run check:versions && npm run check:samples && npm test && npm run build:types && npm run typecheck && npm run build:samples && npm run build:docs && npm run verify:packages && npm run verify:starters",
    "dev:platformer": "vite samples/basic-platformer --host 127.0.0.1 --force",
    "build:platformer": "vite build samples/basic-platformer",
    "dev:top-down": "vite samples/basic-top-down --host 127.0.0.1 --force",
    "build:top-down": "vite build samples/basic-top-down",
    "dev:battle": "vite samples/basic-turn-based-battle --host 127.0.0.1 --force",
    "build:battle": "vite build samples/basic-turn-based-battle",
    "dev:all-in-one": "vite samples/all-in-one --host 127.0.0.1 --force",
    "build:all-in-one": "vite build samples/all-in-one",
    "build:samples": "npm run build:platformer && npm run build:top-down && npm run build:battle && npm run build:all-in-one",
    "dev:docs": "vite docs --host 127.0.0.1",
    "build:docs": "vite build docs",
    "build:pages": "node scripts/build-pages.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "dev:basic-platformer": "vite samples/basic-platformer --host 127.0.0.1 --force",
    "build:basic-platformer": "vite build samples/basic-platformer",
    "dev:basic-top-down-sample": "vite samples/basic-top-down --host 127.0.0.1 --force",
    "build:basic-top-down-sample": "vite build samples/basic-top-down",
    "dev:battle-sample": "vite samples/basic-turn-based-battle --host 127.0.0.1 --force",
    "build:battle-sample": "vite build samples/basic-turn-based-battle"
  },
  "devDependencies": {
    "phaser": "^4.2.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
