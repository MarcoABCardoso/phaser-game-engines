{
  "name": "phaser-game-engines",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/MarcoABCardoso/phaser-game-engines#readme",
  "bugs": "https://github.com/MarcoABCardoso/phaser-game-engines/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoABCardoso/phaser-game-engines.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:headless": "vitest run packages/toolkit/modules/core/tests/headless-exports.test.js",
    "build:types": "tsc -p packages/toolkit/modules/core/tsconfig.types.json && tsc -p packages/toolkit/modules/platformer/tsconfig.types.json && tsc -p packages/toolkit/modules/top-down/tsconfig.types.json && tsc -p packages/toolkit/modules/turn-based-battle/tsconfig.types.json",
    "typecheck": "tsc -p tests/types/tsconfig.json",
    "check:repo": "node scripts/check-repository.mjs",
    "check:versions": "node scripts/version-packages.mjs --check",
    "check:release": "node scripts/check-release-readiness.mjs",
    "version:packages": "node scripts/version-packages.mjs",
    "verify:packages": "node scripts/verify-packages.mjs",
    "verify:starters": "node scripts/verify-starters.mjs",
    "create:game": "node packages/create-game/bin/create-game.js",
    "content": "node packages/toolkit/modules/content-tools/bin/pge-content.js",
    "verify": "npm run check:repo && npm run check:versions && npm test && npm run build:types && npm run typecheck && npm run build:samples && npm run build:docs && npm run verify:packages && npm run verify:starters",
    "dev:platformer": "vite samples/basic-platformer --host 127.0.0.1",
    "build:platformer": "vite build samples/basic-platformer",
    "dev:top-down": "vite samples/basic-top-down --host 127.0.0.1",
    "build:top-down": "vite build samples/basic-top-down",
    "dev:top-down-non-combat": "vite samples/non-combat-top-down --host 127.0.0.1",
    "build:top-down-non-combat": "vite build samples/non-combat-top-down",
    "dev:battle": "vite samples/basic-turn-based-battle --host 127.0.0.1",
    "build:battle": "vite build samples/basic-turn-based-battle",
    "dev:battle-pp": "vite samples/pp-turn-based-battle --host 127.0.0.1",
    "build:battle-pp": "vite build samples/pp-turn-based-battle",
    "dev:battle-negotiation": "vite samples/negotiation-turn-based-battle --host 127.0.0.1",
    "build:battle-negotiation": "vite build samples/negotiation-turn-based-battle",
    "build:samples": "npm run build:platformer && npm run build:top-down && npm run build:top-down-non-combat && npm run build:battle && npm run build:battle-pp && npm run build:battle-negotiation",
    "dev:docs": "vite docs --host 127.0.0.1",
    "build:docs": "vite build docs",
    "benchmark": "node scripts/benchmark.mjs",
    "dev:basic-platformer": "vite samples/basic-platformer --host 127.0.0.1",
    "build:basic-platformer": "vite build samples/basic-platformer",
    "dev:basic-top-down-sample": "vite samples/basic-top-down --host 127.0.0.1",
    "build:basic-top-down-sample": "vite build samples/basic-top-down",
    "dev:non-combat-top-down-sample": "vite samples/non-combat-top-down --host 127.0.0.1",
    "build:non-combat-top-down-sample": "vite build samples/non-combat-top-down",
    "dev:battle-sample": "vite samples/basic-turn-based-battle --host 127.0.0.1",
    "build:battle-sample": "vite build samples/basic-turn-based-battle",
    "dev:pp-battle-sample": "vite samples/pp-turn-based-battle --host 127.0.0.1",
    "build:pp-battle-sample": "vite build samples/pp-turn-based-battle",
    "dev:negotiation-battle-sample": "vite samples/negotiation-turn-based-battle --host 127.0.0.1",
    "build:negotiation-battle-sample": "vite build samples/negotiation-turn-based-battle"
  },
  "devDependencies": {
    "phaser": "^3.90.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
